{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:write-all",
    "fs:read-all",
    "fs:scope",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$DESKTOP/**"
        },
        {
          "path": "$DOCUMENT/**"
        },
        {
          "path": "$DOWNLOAD/**"
        },
        {
          "path": "$PICTURE/**"
        },
        {
          "path": "$HOME/**"
        },
        {
          "path": "**"
        }
      ]
    },
    "dialog:default",
    "fs:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-image"
  ]
}